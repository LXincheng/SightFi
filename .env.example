# SightFi runtime ports
API_PORT=3000
WEB_PORT=5173
VITE_API_BASE_URL=

# Supabase (for upcoming Phase 0 -> Phase 1 integration)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@host:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:password@host:5432/postgres

# Optional external market/news providers
MARKET_DATA_PROVIDER=yahoo
MARKET_DATA_API_KEY=
NEWS_DATA_PROVIDER=auto
NEWS_DATA_API_KEY=
FMP_API_KEY=
NEWSAPI_KEY=
GNEWS_API_KEY=
ALLOW_MOCK_FALLBACK=false
AKSHARE_BASE_URL=

# Third-party AI providers (OpenAI-compatible)
AI_PRIMARY_BASE_URL=https://www.packyapi.com/v1
AI_PRIMARY_MODEL=gpt-5.2
AI_PRIMARY_API_KEY=
AI_FALLBACK_BASE_URL=https://api.deepseek.com/v1
AI_FALLBACK_MODEL=deepseek-reasoner
AI_FALLBACK_API_KEY=
